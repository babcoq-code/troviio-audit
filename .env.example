# ===== PICKSY — Variables d'environnement =====
# Copie ce fichier en .env et remplis les valeurs
# ATTENTION : Ne jamais committer .env sur GitHub

# Application
APP_ENV=production
APP_DEBUG=false
SECRET_KEY=                          # python3 -c "import secrets; print(secrets.token_urlsafe(64))"
ALLOWED_ORIGINS=https://picksy.fr,https://www.picksy.fr

# Domaine
DOMAIN=picksy.fr

# DeepSeek (IA)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# Supabase (Base de données)
SUPABASE_URL=
SUPABASE_KEY=                        # Clé "anon public"
SUPABASE_SERVICE_KEY=                # Clé "service_role" (pour Celery)

# Redis (réseau Docker interne — ne pas modifier)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Newsletter
RESEND_API_KEY=
RESEND_FROM_EMAIL=newsletter@picksy.fr

# Firecrawl (Scraping)
FIRECRAWL_API_KEY=

# Icecat (Données produits)
ICECAT_USERNAME=
ICECAT_PASSWORD=

# Amazon Associates
AMAZON_AFFILIATE_TAG=troviio-21
