<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 630" width="1200" height="630">
  <rect width="1200" height="630" fill="#0E1020"/>
  <text x="600" y="280" text-anchor="middle" font-family="Inter, sans-serif" font-size="80" font-weight="700" fill="#FFFFFF">Troviio</text>
  <text x="600" y="350" text-anchor="middle" font-family="Inter, sans-serif" font-size="28" fill="#8B8FA3">Le comparateur IA de produits</text>
  <rect x="400" y="450" width="400" height="4" rx="2" fill="url(#grad)"/>
  <defs>
    <linearGradient id="grad" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#FF6B5F"/>
      <stop offset="50%" stop-color="#FFB020"/>
      <stop offset="100%" stop-color="#3ED6A3"/>
    </linearGradient>
  </defs>
</svg>
